# Base de datos
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=cuentitas
POSTGRES_USER=cuentitas
POSTGRES_PASSWORD=cambiar_esto

DATABASE_URL=postgresql://cuentitas:cambiar_esto@db:5432/cuentitas

# Auth
JWT_SECRET=cambiar_esto_por_un_string_largo_y_aleatorio

# Bot de WhatsApp (superficie solo-bot). Clave única que el bot manda en el header
# X-Bot-Key. Dejar vacío deshabilita la superficie del bot (devuelve 503).
BOT_API_KEY=cambiar_esto_por_otro_string_largo_y_aleatorio

# Admin inicial (se crea en el primer seed)
ADMIN_USER=Augusto
ADMIN_PASS=cambiar_esto

# App
APP_PORT=8080
TZ=America/Argentina/Buenos_Aires

# Dólar API
DOLAR_API=https://dolarapi.com/v1/dolares

# Dominio (para CORS y cookies en producción)
# Dejar vacío hasta tener dominio
DOMINIO=
